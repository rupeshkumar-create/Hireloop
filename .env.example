# ==========================================================
# Local development — copy to .env and fill in values.
# ==========================================================

# --- Supabase (auth + database + storage) — REQUIRED ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# REQUIRED for API server (port 8000) — not the anon key!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret

# Optional — run SQL migrations via psql
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- OAuth redirect setup (CRITICAL for live login) ---
# If login redirects to localhost after Google/LinkedIn, Supabase Site URL is wrong.
#
# Supabase Dashboard → Authentication → URL Configuration
#   Site URL:        https://hireloop-xi-swart.vercel.app   ← current Vercel production URL
#   Redirect URLs:   https://hireloop-xi-swart.vercel.app/**
#                    http://localhost:3001/**           (local dev only)
# Google Cloud Console → OAuth 2.0 Client
#   Authorized redirect URI: https://YOUR_PROJECT.supabase.co/auth/v1/callback
#   Authorized JavaScript origins: https://hireloop-xi.vercel.app, http://localhost:3001
# LinkedIn Developer app → Auth → Redirect URL:
#   https://YOUR_PROJECT.supabase.co/auth/v1/callback

# --- AI (required for Scout, chat, resume parse) ---
OPENROUTER_API_KEY=your_openrouter_api_key
VITE_OPENROUTER_API_KEY=your_openrouter_api_key

# --- Job discovery (optional — Scout needs this for live jobs) ---
APIFY_API_TOKEN=your_apify_api_token
JOB_DISCOVERY_MODE=apify

# --- Local dev ---
VITE_SITE_URL=http://localhost:3001
VITE_ALLOW_UNLIMITED_REGEN=true
CONNECTION_DASHBOARD_URL=http://localhost:3001/dashboard
API_PORT=8000
VITE_SUPER_ADMIN_PASSWORD=local-dev-admin

# --- Optional ---
# RESEND_API_KEY=          # connect-with-recruiter emails
# APOLLO_API_KEY=
# CRON_SECRET=local-cron   # only if calling /api/cron/* manually

# ==========================================================
# Run locally:
#   npm install
#   cp .env.example .env   # fill keys above
#   Apply supabase/migrations/*.sql to your Supabase DB
#   npm run dev            # frontend :3001, API :8000
#   Open http://localhost:3001
# ==========================================================
