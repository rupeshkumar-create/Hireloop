# ==========================================================
# Frontend (Vite — exposed to the browser, must be VITE_ prefixed)
# ==========================================================

# OpenRouter API key — used as a fallback for the OpenRouter proxy in dev.
# In production all AI calls flow through the api/openai.ts serverless proxy
# (server-side OPENROUTER_API_KEY below).
VITE_OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Apollo enrichment — server-side only (api/apollo.ts proxy). Do NOT expose in the browser.
APOLLO_API_KEY="your_apollo_api_key_here"

# Password gate for the in-app super-admin tools
VITE_SUPER_ADMIN_PASSWORD="your_secure_admin_password_here"

# Dev-only escape hatch: when "true", lets the dashboard "Generate Daily
# Jobs" button bypass the once-per-day cap so you can iterate on the
# pipeline without waiting until tomorrow. MUST be unset (or "false") in
# production — otherwise users can spam the button and burn Apify and
# OpenRouter credits.
VITE_ALLOW_UNLIMITED_REGEN="false"


# ==========================================================
# Backend / Vercel Serverless Functions + GitHub Actions
# ==========================================================

# Stringified JSON for a Firebase service account with access to:
#   - Firebase Auth (verifyIdToken)
#   - Firestore (read users + write daily_matches / cronRuns)
#
# Vercel: paste as ONE line. Keep \n inside the private_key as the two
# literal characters "\" + "n" — do NOT replace them with real newlines.
# The project_id inside this JSON MUST match firebase-applet-config.json.
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}'

# Required if the Firebase project uses a non-default Firestore database
# (the value of `firestoreDatabaseId` in firebase-applet-config.json).
# Leave unset to use the default Firestore database.
FIRESTORE_DATABASE_ID="your-named-database-id"

# OpenRouter API key for server-side AI calls (api/openai.ts proxy)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Apify token — backend job discovery (jobResearcher + ATS sources)
APIFY_API_TOKEN="your_apify_api_token_here"

# apify (default) or feeds (legacy)
JOB_DISCOVERY_MODE="apify"


# ==========================================================
# Cron + on-demand job dispatch
# ==========================================================

# Secret for manual /api/cron/* calls (optional on Hobby — long jobs use GitHub Actions).
CRON_SECRET="your_cron_secret_here"

# Dodo Payments webhook signature verification (optional but recommended in production)
DODO_WEBHOOK_SECRET="your_dodo_webhook_secret_here"

# Secret used by the dispatcher to authenticate the per-user worker call.
INTERNAL_CRON_SECRET="your_internal_cron_secret_here"

# GitHub Actions dispatch — required in production so Vercel can hand off
# long-running pipelines (Scout + content growth) instead of timing out at 60s.
GITHUB_DISPATCH_TOKEN="github_pat_or_classic_token_here"

# Optional fallback alias. If set, the backend will accept it as the dispatch
# token when GITHUB_DISPATCH_TOKEN is missing.
# GITHUB_PAT="github_pat_or_classic_token_here"

# Optional if your Vercel project is already linked to the correct GitHub repo.
# If unset, the backend uses VERCEL_GIT_REPO_OWNER + VERCEL_GIT_REPO_SLUG.
GITHUB_REPO="owner/repo"

# Optional branch/ref override for GitHub workflow dispatch.
# If omitted, the backend uses VERCEL_GIT_COMMIT_REF and falls back to "main".
# GITHUB_DISPATCH_REF="main"

# GitHub repo secrets for scheduled workflows (not Vercel):
#   generate-jobs.yml + content-cron.yml need FIREBASE_SERVICE_ACCOUNT_KEY, OPENROUTER_API_KEY
#   generate-jobs.yml also needs APIFY_API_TOKEN
