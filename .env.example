# OpenAI API Key (Required for AI features — scoring, email, resume tailoring)
VITE_OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Serper API Key (Required for real remote job search via Google Jobs)
# Get yours at https://serper.dev — free tier: 2,500 searches/month
VITE_SERPER_API_KEY="your_serper_api_key_here"

# Resend API Key (Required for Email features)
VITE_RESEND_API_KEY="your_resend_api_key_here"
VITE_SUPER_ADMIN_PASSWORD="your_secure_admin_password_here"

# ==========================================================
# Backend / Vercel Serverless (Required for Superadmin + crons)
# ==========================================================
#
# Stringified JSON for a Firebase service account with access to:
# - Firebase Auth (verifyIdToken)
# - Firestore (read users collection)
#
# Vercel: Project Settings -> Environment Variables
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"..."}'

# Optional: only set this if you are intentionally using a named Firestore database.
# Leave unset for the default Firestore database.
# FIRESTORE_DATABASE_ID="your-named-database-id"

# Apify (Backend job discovery)
APIFY_API_TOKEN="apify_api_vAZEN0sX5fWHlJI8rYbXSQla16Eue72NdbK"

# apify (default) or feeds (legacy)
JOB_DISCOVERY_MODE="apify"
