{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsx scripts/generate-llms-txt.ts && tsx scripts/generate-sitemap.ts && tsx scripts/generate-og-default.ts && vite build && tsx scripts/prerender-blog-posts.ts",
    "generate:og": "tsx scripts/generate-og-default.ts",
    "generate:prerender": "tsx scripts/prerender-blog-posts.ts",
    "generate:llms": "tsx scripts/generate-llms-txt.ts",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "node scripts/smoke-test-api.mjs",
    "test:watch": "vitest",
    "seed:competitors": "tsx scripts/seed-competitor-posts.ts",
    "seed:geo": "tsx scripts/seed-geo-posts.ts",
    "seed:all": "tsx scripts/seed-all-posts.ts",
    "seed:all:full": "tsx scripts/seed-all-batches.ts",
    "deploy:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "html2canvas-pro": "^2.0.2",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "openai": "^6.34.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "@vercel/node": "^5.7.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "firebase-tools": "^14.20.0",
    "happy-dom": "^20.9.0",
    "marked": "^15.0.12",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^3.2.4"
  }
}
