{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/cron/[job].ts": { "maxDuration": 300 },
    "api/blog/index.ts": { "maxDuration": 60 },
    "api/blog/[[...route]].ts": { "maxDuration": 60 },
    "api/openai.ts": { "maxDuration": 60 },
    "api/apollo.ts": { "maxDuration": 60 },
    "api/ai/openai.ts": { "maxDuration": 60 },
    "api/ai/apollo.ts": { "maxDuration": 60 },
    "api/admin/content-growth.ts": { "maxDuration": 300 },
    "api/admin/[[...route]].ts": { "maxDuration": 300 },
    "api/ai/[[...route]].ts": { "maxDuration": 60 },
    "api/public/[[...route]].ts": { "maxDuration": 30 },
    "api/jobs/index.ts": { "maxDuration": 60 },
    "api/webhook/dodo.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    {
      "source": "/api/cron",
      "destination": "/api/cron/tick"
    },
    {
      "source": "/api/analytics/pageview",
      "destination": "/api/public/analytics/pageview"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/public/sitemap"
    },
    {
      "source": "/blog/rss.xml",
      "destination": "/api/blog/rss.xml"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
