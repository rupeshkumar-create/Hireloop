{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/BingSiteAuth.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ],
  "functions": {
    "api/[[...route]].ts": { "maxDuration": 300 }
  },
  "rewrites": [
    { "source": "/api/openai", "destination": "/api/ai/openai" },
    { "source": "/api/apollo", "destination": "/api/ai/apollo" },
    { "source": "/api/cron", "destination": "/api/cron/tick" },
    { "source": "/api/analytics/pageview", "destination": "/api/public/analytics/pageview" },
    { "source": "/blog/rss.xml", "destination": "/api/blog/rss.xml" },
    { "source": "/BingSiteAuth.xml", "destination": "/api/public/bing-site-auth" },
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-alerts",
      "schedule": "0 8 * * *"
    }
  ]
}
