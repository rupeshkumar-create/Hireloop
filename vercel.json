{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/jobs/index.ts": { "maxDuration": 60 },
    "api/cron/process-user.ts": { "maxDuration": 60 },
    "api/cron/daily-alerts.ts": { "maxDuration": 60 },
    "api/openai.ts": { "maxDuration": 60 },
    "api/apollo.ts": { "maxDuration": 30 },
    "api/admin/users.ts": { "maxDuration": 30 },
    "api/admin/content-growth.ts": { "maxDuration": 300 },
    "api/cron/daily-blog.ts": { "maxDuration": 300 },
    "api/cron/monthly-learning.ts": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/cron/daily-alerts",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/daily-blog",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly-analysis",
      "schedule": "0 6 * * 6"
    },
    {
      "path": "/api/cron/monthly-learning",
      "schedule": "0 7 1 * *"
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/blog/rss.xml",
      "destination": "/api/blog/rss.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

