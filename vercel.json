{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.hireschema.com" }],
      "destination": "https://hireschema.com/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/cron/[job].ts": { "maxDuration": 60 },
    "api/blog/index.ts": { "maxDuration": 60 },
    "api/blog/[[...route]].ts": { "maxDuration": 60 },
    "api/admin/[[...route]].ts": { "maxDuration": 60 },
    "api/ai/[[...route]].ts": { "maxDuration": 60 },
    "api/public/[[...route]].ts": { "maxDuration": 30 },
    "api/jobs/index.ts": { "maxDuration": 60 },
    "api/webhook/dodo.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    {
      "source": "/api/openai",
      "destination": "/api/ai/openai"
    },
    {
      "source": "/api/apollo",
      "destination": "/api/ai/apollo"
    },
    {
      "source": "/api/cron",
      "destination": "/api/cron/tick"
    },
    {
      "source": "/api/analytics/pageview",
      "destination": "/api/public/analytics/pageview"
    },
    {
      "source": "/blog/rss.xml",
      "destination": "/api/blog/rss.xml"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
